#define DEF 0
#define NUM 1
#define SYM 2
#define EXT 3
#define MOU 4
#define SCR 5
#define SNI 6

ZMK_HOLD_TAP(hml,
    flavor = "balanced";
    tapping-term-ms = <250>;
    quick-tap-ms = <175>;
    require-prior-idle-ms = <80>;
    bindings = <&kp>, <&kp>;
    hold-trigger-on-release;
)

