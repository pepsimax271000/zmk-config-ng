ZMK_LAYER(base,
		&kp Q          &kp W       &kp E         &kp R          &kp T                                  &kp Y       &kp U            &kp I         &kp O       &kp P         
		&hml LGUI A    &hml LALT S &hml LSHFT D  &hml LCTRL F   &kp G &trans                    &kp SEMI &kp H       &hmr LCTRL J     &hmr RSHFT K  &hmr LALT L &hmr LGUI APOS
    &lt_sni 6 Z    &kp X       &kp C         &kp V          &kp B &trans                    &trans &kp N       &kp M            &kp COMMA     &kp DOT     &kp FSLH
    &kp LCTRL  		 &kp LALT    &kp LGUI      &lt_scr 5 ESC &lt_tab 1 TAB  &lt_shift LSHFT SPACE &kp RET        &lt_back 2 BSPC                            &mo 3
)

